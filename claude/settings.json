{
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "effortLevel": "high",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "75",
    "CLAUDE_CODE_SCROLL_SPEED": "5",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '~/.claude/hooks/herdr-agent-state.sh' session || true",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "printf '\\a' > $TTY || true",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "language": "japanese",
  "model": "sonnet",
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(gemini:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(lsof:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(test:*)",
      "Bash(du:*)",
      "Bash(grep:*)",
      "Bash(/usr/bin/du:*)",
      "Bash(/usr/bin/grep:*)",
      "Bash(npm install:*)",
      "Bash(npm run:*)",
      "Bash(npm uninstall:*)",
      "Bash(npx husky:*)",
      "Bash(poetry run python test:*)",
      "Bash(pytest:*)",
      "Bash(uv run pytest:*)",
      "Bash(pre-commit run:*)",
      "Bash(git checkout:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git switch:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(ipconfig getifaddr:*)",
      "Bash(mise list:*)",
      "Bash(flutter run:*)",
      "Bash(flutter pub get:*)",
      "Bash(flutter build:*)",
      "Bash(codex exec:*)",
      "Edit(./src/**)",
      "Edit(~/.npm/**)",
      "Edit(~/.cache/**)",
      "Edit(//tmp/**)",
      "Skill(codex)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "mcp__serena",
      "mcp__codex__codex",
      "mcp__chrome-devtools",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__close_page",
      "mcp__chrome-devtools__select_page",
      "mcp__chrome-devtools__get_console_message",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__fill",
      "mcp__chrome-devtools__wait_for",
      "mcp__chrome-devtools__evaluate_script"
    ],
    "defaultMode": "acceptEdits",
    "deny": [
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(./.env)",
      "Read(./credentials/**)",
      "Read(./*credentials*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(gh issue create:*)",
      "Bash(gh issue delete:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr close:*)",
      "Bash(gh repo delete:*)",
      "Bash(git push:*)"
    ]
  },
  "sandbox": {
    "allowUnsandboxedCommands": false,
    "autoAllowBashIfSandboxed": true,
    "credentials": {
      "envVars": [
        {
          "mode": "deny",
          "name": "GITHUB_TOKEN"
        },
        {
          "mode": "deny",
          "name": "OPENAI_API_KEY"
        },
        {
          "mode": "deny",
          "name": "GEMINI_API_KEY"
        },
        {
          "mode": "deny",
          "name": "ANTHROPIC_API_KEY"
        },
        {
          "mode": "deny",
          "name": "CLAUDE_CODE_OAUTH_TOKEN"
        }
      ],
      "files": [
        {
          "mode": "deny",
          "path": "~/.ssh"
        },
        {
          "mode": "deny",
          "path": "~/.aws/credentials"
        },
        {
          "mode": "deny",
          "path": "~/.config/gcloud"
        },
        {
          "mode": "deny",
          "path": "~/.kube/config"
        }
      ]
    },
    "enabled": true,
    "failIfUnavailable": true,
    "filesystem": {
      "denyRead": [
        "./.env",
        "./credentials/**",
        "./*credentials*",
        "./secrets/**",
        "**/*.pem",
        "**/*.key",
        "~/.ssh",
        "~/.aws"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  },
  "theme": "dark"
}